{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Backend (FastAPI/uvicorn)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["--app-dir", "backend", "app.main:app", "--reload", "--port", "8000"],
      "port": 8000
    }
  ]
}
